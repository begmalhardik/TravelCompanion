<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/tvAppHeading"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/app_heading"
        android:textColor="@color/black"
        android:fontFamily="sans-serif-black"
        android:textSize="18sp"
        android:padding="4dp"
        android:layout_margin="10dp"
        app:layout_constraintTop_toTopOf="parent" />

    <Spinner
        android:id="@+id/categorySpinner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="5dp"
        android:layout_margin="10dp"
        app:layout_constraintTop_toBottomOf="@id/tvAppHeading" />

    <EditText
        android:id="@+id/inputValue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:importantForAutofill="no"
        android:paddingHorizontal="15dp"
        android:paddingVertical="7dp"
        android:layout_margin="10dp"
        android:inputType="text"
        android:hint="@string/enter_value"
        android:background="none"
        app:layout_constraintTop_toBottomOf="@id/categorySpinner" />

    <Spinner
        android:id="@+id/fromUnitSpinner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="5dp"
        android:layout_margin="10dp"
        app:layout_constraintTop_toBottomOf="@id/inputValue" />

    <Spinner
        android:id="@+id/toUnitSpinner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="5dp"
        android:layout_margin="10dp"
        app:layout_constraintTop_toBottomOf="@id/fromUnitSpinner" />

    <Button
        android:id="@+id/btnConvert"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        android:text="@string/convert"
        android:textSize="18sp"
        app:layout_constraintTop_toBottomOf="@id/toUnitSpinner" />

    <TextView
        android:id="@+id/tvResultHeading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/result"
        android:textColor="@color/black"
        android:fontFamily="sans-serif-black"
        android:textSize="18sp"
        android:padding="4dp"
        android:layout_margin="10dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnConvert" />

    <TextView
        android:id="@+id/tvResult"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="@color/black"
        android:fontFamily="sans-serif-light"
        android:textSize="18sp"
        android:padding="4dp"
        android:layout_marginVertical="10dp"
        android:layout_marginEnd="10dp"
        app:layout_constraintStart_toEndOf="@id/tvResultHeading"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnConvert" />


</androidx.constraintlayout.widget.ConstraintLayout>